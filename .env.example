# Copy this file to .env and fill in your real values.
# Never commit .env to Git.
#
# If this file exists and defines DATABASE_URL, it overrides the process
# environment variable of the same name (useful when DATABASE_URL is also
# injected by a host environment).
#
# Local dev without Postgres: omit DATABASE_URL entirely (do not copy the
# placeholder line below). The API and pipeline then use SQLite at
# data/callit_local.db automatically.
#
# Or force SQLite even if DATABASE_URL is set (broken cloud / bad credentials):
#   CALLIT_USE_SQLITE=1

# Supabase Database (Settings → Database → Connection string URI)
# Prefer the "Direct connection" string (db.<project>.supabase.co:5432) here.
# If your network cannot reach IPv6-only hosts, CallIt rewrites direct URLs to
# the session pooler (IPv4) at runtime. Override region if needed:
#   SUPABASE_POOLER_REGION=us-west-2
# Disable auto-rewrite (use only the URL below as-is):
#   CALLIT_USE_SESSION_POOLER=0
#
# You may instead set DATABASE_URL to session pooler explicitly. Copy the host
# from the dashboard (may be aws-0-* or aws-1-* — do not guess):
# postgresql://postgres.<PROJECT_REF>:[PASSWORD]@<POOLER_HOST_FROM_DASHBOARD>:5432/postgres
#
# Optional if dashboard host differs from auto-rewrite:
# SUPABASE_POOLER_HOST=aws-1-us-east-2.pooler.supabase.com
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Supabase API (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_anon_public_key_here
